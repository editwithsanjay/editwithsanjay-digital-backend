# Database
MONGODB_URI=your_mongodb_connection_string

# JWT Secrets
SECRET_KEY_ACCESS_TOKEN=your_access_token_secret
SECRET_KEY_REFRESH_TOKEN=your_refresh_token_secret

# Frontend URL
FRONTEND_URL=https://your-frontend-domain.com

# Email Configuration
SENDER_EMAIL=your_email@gmail.com
EMAIL_PASS=your_app_password

# Cloudinary Configuration
CLODINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLODINARY_API_KEY=your_cloudinary_api_key
CLODINARY_API_SECRET_KEY=your_cloudinary_api_secret

# Payment Gateway - Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Payment Gateway - Cashfree
CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret

# Server URL (will be auto-generated after deployment)
SERVER_URL=https://your-api-gateway-url.amazonaws.com/dev
